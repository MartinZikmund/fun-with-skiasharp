<Page x:Class="GravityWells.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:GravityWells"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <!-- Grid with a (transparent) Background is reliably hit-testable, so pointer
       events fire here and are forwarded to the canvas. -->
  <Grid x:Name="Root" Background="Transparent"
        PointerPressed="OnPointerPressed"
        PointerMoved="OnPointerMoved"
        PointerReleased="OnPointerReleased"
        PointerWheelChanged="OnPointerWheel">

    <local:DemoCanvas x:Name="Canvas" />

    <!-- Fluent control overlay, bottom-right and out of the way. -->
    <StackPanel Orientation="Horizontal"
                Spacing="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24">
      <Button Content="Add random"
              Click="OnAddRandom"
              Background="#332E68FF"
              BorderBrush="#552E68FF"
              Foreground="White" />
      <Button Content="Reset"
              Click="OnReset"
              Background="#33FF6A3D"
              BorderBrush="#55FF6A3D"
              Foreground="White" />
    </StackPanel>

  </Grid>
</Page>

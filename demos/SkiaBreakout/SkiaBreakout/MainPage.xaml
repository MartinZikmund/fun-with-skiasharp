<Page x:Class="SkiaBreakout.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SkiaBreakout"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <!-- IsTabStop + programmatic Focus makes the Grid receive KeyDown/KeyUp.
       Transparent Background makes it hit-testable for pointer events. -->
  <Grid x:Name="Root" Background="Transparent" IsTabStop="True"
        Loaded="OnLoaded"
        KeyDown="OnKeyDown"
        KeyUp="OnKeyUp"
        PointerPressed="OnPointerPressed"
        PointerMoved="OnPointerMoved"
        PointerReleased="OnPointerReleased"
        PointerWheelChanged="OnPointerWheel">

    <local:DemoCanvas x:Name="Canvas" />

    <!-- Tasteful Fluent overlay: New Game button (score/lives are drawn on the canvas). -->
    <Button x:Name="RestartButton"
            Content="New Game"
            Click="OnRestartClick"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,16,44"
            Padding="16,8"
            CornerRadius="8" />

  </Grid>
</Page>

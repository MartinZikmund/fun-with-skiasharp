<Page x:Class="SkiaGallery.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SkiaGallery"
      Background="#06070D">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Padding="30,30,30,10" Spacing="6">
      <TextBlock Text="UNO PLATFORM &#215; SKIASHARP 4" Foreground="#39D0FF" FontSize="12"
                 CharacterSpacing="320" />
      <TextBlock Text="Fun with SkiaSharp" FontSize="42" FontWeight="Bold" Foreground="#EEF1FB" />
      <TextBlock Foreground="#9AA3C0" TextWrapping="Wrap" MaxWidth="820" HorizontalAlignment="Left"
                 Text="Nineteen demos drawing through SKCanvasElement on SkiaSharp 4.148.0. Tap a tile to run it live, then Back to pick another." />
    </StackPanel>

    <GridView Grid.Row="1" x:Name="Tiles"
              IsItemClickEnabled="True" ItemClick="OnItemClick"
              SelectionMode="None" Padding="24,8,24,24">
      <GridView.ItemContainerStyle>
        <Style TargetType="GridViewItem">
          <Setter Property="Margin" Value="8" />
          <Setter Property="Padding" Value="0" />
        </Style>
      </GridView.ItemContainerStyle>
      <GridView.ItemTemplate>
        <DataTemplate>
          <Grid Width="320" CornerRadius="14" Background="#10131F"
                BorderBrush="#222840" BorderThickness="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="204" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
              <Image Source="{Binding Thumb}" Stretch="UniformToFill" />
              <Border Background="#AA000000" CornerRadius="8" Padding="7,3"
                      HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                <TextBlock Text="{Binding RankLabel}" Foreground="White" FontWeight="Bold" FontSize="12" />
              </Border>
              <Border Background="#AA101A2A" CornerRadius="8" Padding="7,3" BorderBrush="#33558899" BorderThickness="1"
                      HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                <TextBlock Text="{Binding Badge}" Foreground="#9FE0FF" FontSize="11" />
              </Border>
            </Grid>

            <StackPanel Grid.Row="1" Padding="14,12,14,14" Spacing="4">
              <TextBlock Text="{Binding Name}" Foreground="#EEF1FB" FontWeight="SemiBold" FontSize="16" />
              <TextBlock Text="{Binding OneLiner}" Foreground="#C2CAE6" TextWrapping="Wrap"
                         MaxLines="3" TextTrimming="CharacterEllipsis" FontSize="13" Height="56" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </GridView.ItemTemplate>
    </GridView>
  </Grid>
</Page>
